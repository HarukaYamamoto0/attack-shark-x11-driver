{
	"private": true,
	"name": "attack-shark-driver",
	"version": "1.0.0",
	"description": "",
	"main": "dist/index.js",
	"type": "module",
	"scripts": {
		"build": "tsc",
		"lint": "eslint . --ext .ts --cache --cache-strategy content",
		"lint:fix": "eslint . --ext .ts --fix --cache --cache-strategy content",
		"format": "prettier --check . --cache --cache-strategy content",
		"format:fix": "prettier --write . --cache --cache-strategy content",
		"typecheck": "tsc --noEmit",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{ts,js,json}": [
			"prettier --write",
			"eslint --fix"
		]
	},
	"dependencies": {
		"pino": "10.3.1",
		"usb": "2.17.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/bun": "^1.3.9",
		"@types/node": "^25.0.10",
		"eslint": "^10.0.2",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"jiti": "^2.6.1",
		"lint-staged": "^16.3.2",
		"prettier": "3.8.1",
		"typescript": "^5.5.3",
		"typescript-eslint": "^8.56.1"
	}
}
